{
  "name": "@nora/pages-aboutdialog",
  "exports": "./dist/main.js",
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.5",
    "preact": "npm:preact@^10.25.4",
    "preact/compat": "npm:preact@^10.25.4/compat",
    "preact/hooks": "npm:preact@^10.25.4/hooks",
    "@preact/signals": "npm:@preact/signals@^1.3.1",
    "vite": "npm:vite@^7.1.4",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4.3.4",
    "i18next": "npm:i18next@^25.7.3",
    "react-i18next": "npm:react-i18next@^16.5.0",
    "i18next-browser-languagedetector": "npm:i18next-browser-languagedetector@^8.2.0"
  },
  "tasks": {
    "build": "deno run -A npm:vite build"
  },
  "compilerOptions": {
